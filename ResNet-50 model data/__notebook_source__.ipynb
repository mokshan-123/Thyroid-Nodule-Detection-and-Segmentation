# ── Preprocessing constants (IDENTICAL to RCNN + DenseNet — DO NOT CHANGE) ─

CLAHE_CLIP     = 2.0
CLAHE_GRID     = (8, 8)
CROP_MARGIN    = 30          
RESIZE_SIZE    = 224         

LABEL_MAP      = {"0": 0, "1": 1}   
