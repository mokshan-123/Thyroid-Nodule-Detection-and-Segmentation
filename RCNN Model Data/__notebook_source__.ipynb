# Background MUST be 0 for Faster R-CNN
# benign("0" in XML)   → label 1
# malignant("1" in XML) → label 2
LABEL_MAP   = {"0": 1, "1": 2}
NUM_CLASSES = 3   # 0=background, 1=benign, 2=malignant

class ThyroidDataset(Dataset):
    def __init__(self, img_ids, preprocessed_path, annotations_path, augment=False):
        self.img_ids           = img_ids
        self.preprocessed_path = preprocessed_path
        self.annotations_path  = annotations_path
        self.augment           = augment
    def __len__(self):
        return len(self.img_ids)
    def __getitem__(self, idx):
        img_id   = self.img_ids[idx]
        img_path = os.path.join(self.preprocessed_path, img_id + ".jpg")
        xml_path = os.path.join(self.annotations_path,  img_id + ".xml")
        img        = Image.open(img_path).convert("RGB")
        img_tensor = TF.to_tensor(img)
        tree   = ET.parse(xml_path)
        root   = tree.getroot()
        boxes, labels = [], []
        for obj in root.findall("object"):
            cls  = obj.find("name").text.strip()
            xmin = int(obj.find("bndbox/xmin").text)
            ymin = int(obj.find("bndbox/ymin").text)
            xmax = int(obj.find("bndbox/xmax").text)
            ymax = int(obj.find("bndbox/ymax").text)
            if xmax > xmin and ymax > ymin:
                boxes.append([xmin, ymin, xmax, ymax])
                labels.append(LABEL_MAP.get(cls, 1))
        boxes  = torch.as_tensor(boxes,  dtype=torch.float32)
        labels = torch.as_tensor(labels, dtype=torch.int64)
        if self.augment:
            if random.random() > 0.5:
                img_tensor = TF.hflip(img_tensor)
                if len(boxes) > 0:
                    w = img_tensor.shape[2]
                    boxes[:, [0, 2]] = w - boxes[:, [2, 0]]
            if random.random() > 0.3:
                img_tensor = TF.vflip(img_tensor)
                if len(boxes) > 0:
                    h = img_tensor.shape[1]
                    boxes[:, [1, 3]] = h - boxes[:, [3, 1]]
            if random.random() > 0.5:
                img_tensor = TF.adjust_brightness(img_tensor,
                                brightness_factor=random.uniform(0.8, 1.2))
            if random.random() > 0.5:
                img_tensor = TF.adjust_contrast(img_tensor,
                                contrast_factor=random.uniform(0.8, 1.2))
        target = {
            "boxes":    boxes,
            "labels":   labels,
            "image_id": torch.tensor([idx])
        }
        return img_tensor, target

def collate_fn(batch):
    return tuple(zip(*batch))


def build_fasterrcnn(num_classes=NUM_CLASSES, trainable_layers=1):
    model      = fasterrcnn_resnet50_fpn_v2(weights="DEFAULT",
                                             trainable_backbone_layers=trainable_layers)
    
    in_features = model.roi_heads.box_predictor.cls_score.in_features
    model.roi_heads.box_predictor = FastRCNNPredictor(in_features, num_classes)
    
    return model


