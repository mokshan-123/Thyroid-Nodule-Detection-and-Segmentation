import matplotlib.patches as patches

def visualize_augmented_samples(dataset, n=6):
    """
    Visualize n random augmented samples from the dataset
    with bounding boxes and class labels drawn on them
    """
    LABEL_NAMES = {1: "benign", 2: "malignant"}
    COLORS      = {1: "green", 2: "red"}

    fig, axes = plt.subplots(2, 3, figsize=(18, 10))
    axes = axes.flatten()

    # pick n random indices
    indices = random.sample(range(len(dataset)), n)

    for i, idx in enumerate(indices):
        img_tensor, target = dataset[idx]

        # convert tensor [3, H, W] → numpy [H, W, 3] for display
        img_np = img_tensor.permute(1, 2, 0).numpy()
        img_np = np.clip(img_np, 0, 1)

        axes[i].imshow(img_np)

        # draw each bounding box
        boxes  = target["boxes"]
        labels = target["labels"]

        for box, label in zip(boxes, labels):
            xmin, ymin, xmax, ymax = box.tolist()
            width  = xmax - xmin
            height = ymax - ymin

            label_id   = label.item()
            class_name = LABEL_NAMES.get(label_id, "unknown")
            color      = COLORS.get(label_id, "orange")

            # draw rectangle
            rect = patches.Rectangle(
                (xmin, ymin), width, height,
                linewidth=2, edgecolor=color, facecolor="none"
            )
            axes[i].add_patch(rect)

            # draw label text
            axes[i].text(
                xmin, max(ymin - 5, 10),
                class_name,
                color=color,
                fontsize=10,
                fontweight="bold",
                bbox=dict(facecolor="black", alpha=0.4, pad=2)
            )

        img_id = dataset.img_ids[idx]
        axes[i].set_title(f"ID: {img_id}", fontsize=9)
        axes[i].axis("off")

    plt.suptitle("Augmented Training Samples with Bounding Boxes", fontsize=13)
    plt.tight_layout()
    plt.show()

# ── Run it on your train dataset ───────────────────────────────────────
visualize_augmented_samples(train_dataset, n=6)


train_losses, val_losses = [], []
best_val_loss  = float("inf")
best_model_wts = None

for epoch in range(NUM_EPOCHS):
    # ---- TRAIN ----
    model.train()
    epoch_loss = 0.0
    t0 = time.time()
    run = {"rpn_obj": 0.0, "rpn_box": 0.0, "cls": 0.0, "box_reg": 0.0}

    train_bar = tqdm_notebook(train_loader,
                              desc=f"Epoch [{epoch+1:02d}/{NUM_EPOCHS}] Train",
                              leave=True)

    for batch_idx, (images, targets) in enumerate(train_bar):
        try:
            images  = [img.to(DEVICE) for img in images]
            targets = [{k: v.to(DEVICE) for k, v in t.items()} for t in targets]

            loss_dict  = model(images, targets)
            total_loss = sum(loss_dict.values())

            optimizer.zero_grad()
            total_loss.backward()
            torch.nn.utils.clip_grad_norm_(
                model.parameters(), max_norm=5.0)
            optimizer.step()

            n = batch_idx + 1
            run["rpn_obj"] += loss_dict["loss_objectness"].item()
            run["rpn_box"] += loss_dict["loss_rpn_box_reg"].item()
            run["cls"]     += loss_dict["loss_classifier"].item()
            run["box_reg"] += loss_dict["loss_box_reg"].item()
            epoch_loss     += total_loss.item()

            train_bar.set_postfix({
                "train_loss" : f"{epoch_loss/n:.4f}",      # ← running train loss
                "rpn_obj"    : f"{run['rpn_obj']/n:.3f}",
                "rpn_box"    : f"{run['rpn_box']/n:.3f}",
                "cls"        : f"{run['cls']/n:.3f}",
                "box_reg"    : f"{run['box_reg']/n:.3f}",
                "lr"         : f"{scheduler.get_last_lr()[0]:.6f}",
                "err"        : "ok"
            })

        except RuntimeError as e:
            err_msg = str(e)[:35]
            train_bar.set_postfix({
                "train_loss" : "---",
                "rpn_obj"    : "---",
                "rpn_box"    : "---",
                "cls"        : "---",
                "box_reg"    : "---",
                "lr"         : f"{scheduler.get_last_lr()[0]:.6f}",
                "err"        : err_msg
            })
            torch.cuda.empty_cache()
            optimizer.zero_grad()
            continue

    scheduler.step()
    avg_train_loss = epoch_loss / len(train_loader)
    train_losses.append(avg_train_loss)

    # ---- VALIDATION ----
    val_loss = 0.0
    val_run  = {"rpn_obj": 0.0, "rpn_box": 0.0, "cls": 0.0, "box_reg": 0.0}

    val_bar = tqdm_notebook(val_loader,
                            desc=f"Epoch [{epoch+1:02d}/{NUM_EPOCHS}] Val  ",
                            leave=True)

    with torch.no_grad():
        for batch_idx, (images, targets) in enumerate(val_bar):
            try:
                images  = [img.to(DEVICE) for img in images]
                targets = [{k: v.to(DEVICE) for k, v in t.items()} for t in targets]

                loss_dict  = model(images, targets)
                batch_loss = sum(loss_dict.values()).item()
                val_loss  += batch_loss

                n = batch_idx + 1
                val_run["rpn_obj"] += loss_dict["loss_objectness"].item()
                val_run["rpn_box"] += loss_dict["loss_rpn_box_reg"].item()
                val_run["cls"]     += loss_dict["loss_classifier"].item()
                val_run["box_reg"] += loss_dict["loss_box_reg"].item()

                val_bar.set_postfix({
                    "val_loss"  : f"{val_loss/n:.4f}",         # ← running val loss
                    "rpn_obj"   : f"{val_run['rpn_obj']/n:.3f}",
                    "rpn_box"   : f"{val_run['rpn_box']/n:.3f}",
                    "cls"       : f"{val_run['cls']/n:.3f}",
                    "box_reg"   : f"{val_run['box_reg']/n:.3f}",
                    "lr"        : f"{scheduler.get_last_lr()[0]:.6f}",
                    "err"       : "ok"
                })

            except RuntimeError as e:
                err_msg = str(e)[:35]
                val_bar.set_postfix({
                    "val_loss"  : "---",
                    "rpn_obj"   : "---",
                    "rpn_box"   : "---",
                    "cls"       : "---",
                    "box_reg"   : "---",
                    "lr"        : f"{scheduler.get_last_lr()[0]:.6f}",
                    "err"       : err_msg
                })
                torch.cuda.empty_cache()
                continue

    avg_val_loss = val_loss / len(val_loader)
    val_losses.append(avg_val_loss)

    if avg_val_loss < best_val_loss:
        best_val_loss  = avg_val_loss
        best_model_wts = copy.deepcopy(model.state_dict())
        torch.save(best_model_wts,
                   os.path.join(SAVE_DIR, "best_fasterrcnn.pth"))

    elapsed = time.time() - t0
    # ── clean epoch summary line ───────────────────────────────────────
    print(f"Epoch [{epoch+1:02d}/{NUM_EPOCHS}]  "
          f"Train Loss: {avg_train_loss:.4f}  "
          f"Val Loss: {avg_val_loss:.4f}  "
          f"LR: {scheduler.get_last_lr()[0]:.6f}  "
          f"Time: {elapsed:.1f}s"
          + (" ✓ best model saved" if avg_val_loss == best_val_loss else ""))

print("\nTraining complete.")


# ── Plot Training Curves ───────────────────────────────────────────────
plt.figure(figsize=(10, 4))
plt.plot(range(1, NUM_EPOCHS+1), train_losses, label="Train Loss", marker="o")
plt.plot(range(1, NUM_EPOCHS+1), val_losses,   label="Val Loss",   marker="s")
plt.xlabel("Epoch"); plt.ylabel("Loss")
plt.title("Faster R-CNN Training Curves")
plt.legend(); plt.grid(True); plt.tight_layout(); plt.show()

# ── Evaluation Metrics ─────────────────────────────────────────────────
from torchvision.ops import box_iou

def evaluate_fasterrcnn(model, data_loader, device, iou_threshold=0.5, score_threshold=0.5):
    """
    Computes per-image IoU, then aggregates:
      Precision = TP / (TP + FP)
      Recall    = TP / (TP + FN)
      mAP@0.5   = mean AP across classes at IoU≥0.5
    """
    model.eval()
    all_ious      = []
    tp = fp = fn  = 0

    with torch.no_grad():
        for images, targets in tqdm(data_loader, desc="Evaluating"):
            images = [img.to(device) for img in images]
            preds  = model(images)      # inference mode → returns boxes+scores+labels

            for pred, target in zip(preds, targets):
                gt_boxes   = target["boxes"].to(device)
                pred_boxes = pred["boxes"]
                scores     = pred["scores"]

                # Filter by confidence threshold
                keep       = scores >= score_threshold
                pred_boxes = pred_boxes[keep]

                if len(gt_boxes) == 0 and len(pred_boxes) == 0:
                    continue
                if len(gt_boxes) == 0:
                    fp += len(pred_boxes)
                    continue
                if len(pred_boxes) == 0:
                    fn += len(gt_boxes)
                    continue

                # IoU matrix [N_pred × N_gt]
                iou_matrix   = box_iou(pred_boxes, gt_boxes)
                max_ious, _  = iou_matrix.max(dim=1)
                all_ious.extend(max_ious.cpu().numpy())

                matched = (max_ious >= iou_threshold)
                tp += matched.sum().item()
                fp += (~matched).sum().item()
                fn += max(0, len(gt_boxes) - matched.sum().item())

    mean_iou  = float(np.mean(all_ious)) if all_ious else 0.0
    precision = tp / (tp + fp + 1e-6)
    recall    = tp / (tp + fn + 1e-6)
    f1        = 2 * precision * recall / (precision + recall + 1e-6)
    # mAP@0.5 approximated as precision × recall area (single-class detection)
    mAP       = precision * recall

    print("\n===== Faster R-CNN Evaluation on Test Set =====")
    print(f"  Mean IoU   : {mean_iou:.4f}")
    print(f"  Precision  : {precision:.4f}")
    print(f"  Recall     : {recall:.4f}")
    print(f"  F1 Score   : {f1:.4f}")
    print(f"  mAP@0.5    : {mAP:.4f}")
    return {"mean_iou": mean_iou, "precision": precision,
            "recall": recall, "f1": f1, "mAP": mAP}

# ── Load best model and evaluate on TEST set ──────────────────────────
model.load_state_dict(torch.load(os.path.join(SAVE_DIR, "best_fasterrcnn.pth")))

test_dataset = ThyroidDataset(test_ids, PREPROCESSED_PATH, annotations_path)
test_loader  = DataLoader(test_dataset, batch_size=2, shuffle=False,
                          collate_fn=collate_fn, num_workers=2)

metrics = evaluate_fasterrcnn(model, test_loader, DEVICE,
                               iou_threshold=0.5, score_threshold=0.5)


LABEL_NAMES = {1: "benign", 2: "malignant"}
COLORS      = {1: (0, 200, 0), 2: (200, 0, 0)}   # green=benign, red=malignant

def visualize_predictions(model, img_ids, preprocessed_path,
                           annotations_path, device, n=6, score_thresh=0.5):
    model.eval()
    fig, axes = plt.subplots(2, 3, figsize=(18, 10))
    axes = axes.flatten()

    for i, img_id in enumerate(img_ids[:n]):
        img_path = os.path.join(preprocessed_path, img_id + ".jpg")
        img_bgr  = cv2.imread(img_path)
        img_rgb  = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2RGB)

        # Run inference
        tensor = TF.to_tensor(Image.open(img_path).convert("RGB")).unsqueeze(0).to(device)
        with torch.no_grad():
            pred = model(tensor)[0]

        # Draw predicted boxes
        for box, label, score in zip(pred["boxes"], pred["labels"], pred["scores"]):
            if score < score_thresh:
                continue
            x1, y1, x2, y2 = map(int, box.tolist())
            name  = LABEL_NAMES.get(label.item(), "?")
            color = COLORS.get(label.item(), (255, 165, 0))
            cv2.rectangle(img_rgb, (x1,y1), (x2,y2), color, 2)
            cv2.putText(img_rgb, f"{name} {score:.2f}",
                        (x1, max(y1-8, 12)), cv2.FONT_HERSHEY_SIMPLEX,
                        0.6, color, 2)

        axes[i].imshow(img_rgb)
        axes[i].set_title(f"Test: {img_id}", fontsize=9)
        axes[i].axis("off")

    plt.suptitle("Faster R-CNN Predictions on Test Images", fontsize=13)
    plt.tight_layout(); plt.show()

visualize_predictions(model, test_ids, PREPROCESSED_PATH,
                      annotations_path, DEVICE, n=6, score_thresh=0.5)









