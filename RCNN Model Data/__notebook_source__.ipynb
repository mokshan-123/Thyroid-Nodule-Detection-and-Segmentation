# ── Weighted Sampler for class imbalance ──────────────────────────────
def get_sample_weights(img_ids, annotations_path):
    weights = []
    class_counts = {"benign": 0, "malignant": 0}
    labels_per_image = []

    for img_id in img_ids:
        xml_path = os.path.join(annotations_path, img_id + ".xml")
        tree = ET.parse(xml_path)
        root = tree.getroot()
        classes = []
        for obj in root.findall("object"):
            cls = obj.find("name").text.strip()
            label = "benign" if cls == "0" else "malignant"
            classes.append(label)
            class_counts[label] += 1
        # use majority class of image as image label
        if classes:
            majority = Counter(classes).most_common(1)[0][0]
        else:
            majority = "benign"
        labels_per_image.append(majority)

    # weight = 1 / class_frequency
    total = len(img_ids)
    class_weights = {
        "benign":    total / (2 * class_counts["benign"]),
        "malignant": total / (2 * class_counts["malignant"])
    }
    weights = [class_weights[lbl] for lbl in labels_per_image]
    return weights

train_weights = get_sample_weights(train_ids, annotations_path)
sampler = WeightedRandomSampler(
    weights=train_weights,
    num_samples=len(train_weights),
    replacement=True
)



train_loader  = DataLoader(train_dataset, batch_size=BATCH_SIZE, sampler=sampler,
                           collate_fn=collate_fn, num_workers=2, pin_memory=True)
