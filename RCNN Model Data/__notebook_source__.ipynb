def count_classes_in_ids(img_ids, annotations_path):
    class_counts = Counter()
    
    for img_id in img_ids:
        xml_path = os.path.join(annotations_path, img_id + ".xml")
        if not os.path.exists(xml_path):
            print(f"Warning: missing {img_id}.xml")
            continue
        tree = ET.parse(xml_path)
        root = tree.getroot()
        for obj in root.findall("object"):
            class_id = obj.find("name").text.strip()
            label = "benign" if class_id == "0" else "malignant"
            class_counts[label] += 1
    
    return class_counts

